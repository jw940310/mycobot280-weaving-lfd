<?xml version="1.0"?>
<!--
  myCobot 280 ros2_control 하드웨어 정의.
  plugin 인자로 하드웨어 구현을 스왑:
   - 시뮬레이션(현재): mock_components/GenericSystem
   - Gazebo(W2):       gz_ros2_control/GazeboSimSystem 등
   - 실기(W7):         pymycobot 기반 자체 hardware_interface
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="mycobot_280_ros2_control" params="name plugin">
    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>${plugin}</plugin>
      </hardware>
      <xacro:macro name="arm_joint" params="joint_name">
        <joint name="${joint_name}">
          <command_interface name="position"/>
          <state_interface name="position">
            <param name="initial_value">0.0</param>
          </state_interface>
          <state_interface name="velocity"/>
        </joint>
      </xacro:macro>
      <xacro:arm_joint joint_name="joint2_to_joint1"/>
      <xacro:arm_joint joint_name="joint3_to_joint2"/>
      <xacro:arm_joint joint_name="joint4_to_joint3"/>
      <xacro:arm_joint joint_name="joint5_to_joint4"/>
      <xacro:arm_joint joint_name="joint6_to_joint5"/>
      <xacro:arm_joint joint_name="joint6output_to_joint6"/>
    </ros2_control>
  </xacro:macro>

</robot>
